# Database Configuration (Optional - fallback values are configured in api/db.php)
# For x10hosting, DB_HOST should remain "localhost"
DB_HOST="localhost"
DB_NAME="your_x10hosting_database_name"
DB_USER="your_x10hosting_database_user"
DB_PASS="your_x10hosting_database_password"

# SMTP Mail Server Configuration (Required for password reset emails)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"
